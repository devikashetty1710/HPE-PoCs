# ============================================================
# AI Document Retrieval Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git.

# --- LLM Provider ---
# Which LLM to use: "groq", "gemini", or "openai"
LLM_PROVIDER=groq

# --- Groq (default — free tier, no credit card needed) ---
# Get your key at: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Gemini (alternative) ---
# Get your key at: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI (alternative) ---
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_MODEL=gpt-4o-mini

# --- FAISS Vector Store ---
# Local folder where the FAISS index is saved (auto-created by ingest.py)
FAISS_DIR=./faiss_db

# --- Document Sources ---
# Folder containing local documents to index
LOCAL_DOCS_DIR=./sample_docs

# Max characters returned per tool call (prevents context overflow)
MAX_CONTENT_LENGTH=4000

# --- Agent Settings ---
MAX_ITERATIONS=4
VERBOSE=true
